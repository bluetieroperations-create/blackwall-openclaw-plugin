# Copy to `blackwall.env` and fill in. NEVER commit blackwall.env (see .gitignore).

# REQUIRED — your BLACK_WALL key (free at https://blackwalltier.com/dashboard/keys):
BLACKWALL_API_KEY=bw_live_xxx

# Gate posture (already baked secure-by-default in the image; override here if needed):
BLACKWALL_MODE=enforce
BLACKWALL_FAIL_CLOSED=1
BLACKWALL_BASE_URL=https://blackwalltier.com

# Only for the FULL agent loop (run-agent.sh), NOT the gate demo — your model provider key:
# OPENROUTER_API_KEY=sk-or-...

# If your droplet has default-deny egress behind a proxy (NemoClaw-style), set this and the
# plugin CONNECT-tunnels through it automatically (Node's global fetch ignores HTTPS_PROXY;
# the plugin's proxy-fetch handles it). Plain droplets don't need this.
# HTTPS_PROXY=http://10.0.0.1:3128
# NO_PROXY=localhost,127.0.0.1
